PORT=4000
NODE_ENV=development

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
# Copy this file to .env. If MySQL rejects root with "using password: NO", you are missing MYSQL_PASSWORD here.
MYSQL_PASSWORD="" 
MYSQL_DATABASE=pulse_shield

JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# Python AI service
AI_SERVICE_URL=http://127.0.0.1:8000

# Minimum loss (same currency as earnings) to auto-trigger a claim
LOSS_THRESHOLD_AMOUNT=50

# Frontend URL for CORS
CORS_ORIGIN=http://localhost:5173
